#slideshow {
	
	border-radius :10px;
	padding: 77px 0 0 0;
	margin : 30px;

	position:center;
	
	width:auto;
	height:450px;
	max-width : 1180px; 
	min-height:450px;
	
	overflow:hidden;
	-webkit-box-shadow:#999999 0px 0px 15px;
	-moz-box-shadow:#999999 0px 0px 15px;
	box-shadow:#999999 0px 0px 25px;


}
#slideshow > div {
	position:absolute;
	width:100%;
	height:100%;
}


#slideshow2 {
	
	border-radius :10px;
	padding: 0px 0 0 0;
	margin : 10px;


	position:center;
	
	width:600px;
	height:50px;
	min-height:50px;
	background-image : url(images/qbody-bg5.png);
	overflow:hidden;
	-webkit-box-shadow:#999999 0px 0px 5px;
	-moz-box-shadow:#999999 0px 0px 5px;
	box-shadow:#999999 0px 0px 5px;

}
#slideshow2 > div {
	position:absolute;
	width:50%;
	height:50%;
}


.control-arrow {
	
	position:absolute;
	
	z-index:300;
	top:540px;
	height:64px;
	width:33px;
	
	background-repeat:no-repeat;
	cursor:pointer;
}
.control-arrow:hover {
	background-position: 0px -65px;

}
.control-arrow:active {
	background-position: 0px -130px;

}
.control-arrow#prev-slide {
	background-image:url('arrow-back.png');
	left:0px;
}
.control-arrow#next-slide {
	background-image:url('arrow-next.png');
	right:0px; /* 752px - 33px */
}

/* Fixed container for a slide's title */
.header {
	display:table; /* this is a bit evil, but it lets us vertically centre stuff */
	position:absolute;
	/* FIXME: better to use position:relative here and for #main.
	   Need to have a specific maximum height, though,
	   which isn't working with display:table */
	margin : 15px;
	padding:5px 5px;
	width:1150px;
	height:68px;
	border-radius : 5px;
	background:url(images/footerBackground.png) repeat-x left ;
	-webkit-box-shadow:#999999 0px 0px 5px;
	-moz-box-shadow:#999999 0px 0px 5px;
	box-shadow:#999999 0px 0px 5px;
	
}

.header > .slidetitle {
	
	display:table-cell;
	/*margin:10px 25px 10px 25px;*/
	padding:20px 20px;
	margin : 20px;
	vertical-align:top;
	
	font-size:20px; /* applies to all lines except first */
	
	font-weight:normal;
	color:#ffffff;

	
	
}
.slidetitle:first-line {
	
	color :#BEBCBC;
	font-size:46px; /* TODO: 24px? */
	line-height:2px;
	left : 50px;

}

.main {
	
	position:absolute;
	top:30px; /* 68px + 2px margin */
	bottom:2px;
	left:20px;
	right:20px;
	min-height:390px; /* 442px (from #slideshow) - 70px - 2px */
	
	/* move this to #slideshow if we don't want the background image to move with slides */
	background-color:#transparent;

}

/*
A slide's body text goes inside here.
Inner space is 224px wide.
*/
.main > .text {
	
	font-size:18px;
	position:absolute;
	top:65px;
	left:5px;
	width:660px;
	bottom:35px;
	min-height:450px; /* 369 - 25 - 15 (for bottom) */
	overflow:auto;
	color: #fff;
	text-shadow: 2px 2px 2px #000;


	
}

.text > div {
	
	border-radius : 10px;
	margin-bottom:4px;
	padding:6px 12px;
	background:transparent;


}
.text > div:last-child {
	margin-bottom:0px;
}

.text > div > .subtitle {
	padding-bottom:2px;
	margin-bottom:5px;
	font-size:inherit;
	font-weight:normal;
	text-decoration:none;
	border-bottom:#333333 dotted 1px;
}

.featured ul {
	display:table;
}
.featured li {
	display:table-row;
}
.featured li > * {
	padding-bottom:12px;
}
.featured li .icon {
	display:table-cell;
	width:24px;
	height:auto;
	padding-right:12px;
}
.featured li .caption {
	display:table-cell;
	vertical-align:middle;
}

.main > .screenshot {
	position:absolute;
	top:95px;
	right:5px; /* offsets 2px margin of .main */
	
	-webkit-box-shadow:#999999 0px 0px 5px;
	-moz-box-shadow:#999999 0px 0px 5px;
	box-shadow:#999999 0px 0px 85px;
}

.main > .screenshot2 {
	position:absolute;
	top:0px;
	right:75px; /* offsets 2px margin of .main */

}

.main > .screenshot3 {
	position:absolute;
	top:430px;
	right:65px; /* offsets 2px margin of .main */
}
/*
This rule disables drag-and-drop for images.  See bug #448703.
*/
img {
 	-webkit-user-drag:none;
}



/* RTL stuff */
.rtl {
	direction:rtl;
}

.rtl .control-arrow#prev-slide {
	background-image:url('arrow-next.png');
	left:19px;
}
.rtl .control-arrow#next-slide {
	background-image:url('arrow-back.png');
	left:20px; /* 752px - 33px */
}

.rtl .main > .text {
	left:auto;
	right:36px;
}

.rtl .main > .screenshot {
	right:normal;
	left:120px;
}

.rtl .featured li .icon {
	padding-right:50px;
	padding-left:212px;
}

